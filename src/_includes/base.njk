{% set allCurios = collections.curiosity | allCuriosities %}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>{% if title %}{{ title }} - {% endif %}每天一个小好奇</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600&family=Playfair+Display:ital,wght@0,500;0,700;1,500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #FAFAF8;
      --surface: #FFFFFF;
      --text: #1A1A1A;
      --text-muted: #5C5A57;
      --accent: #C45C3E;
      --accent-hover: #A84E35;
      --accent-soft: rgba(196, 92, 62, 0.09);
      --border: #E8E4DF;
      --shadow-sm: 0 1px 2px rgba(26, 26, 26, 0.04);
      --shadow-md: 0 12px 48px rgba(26, 26, 26, 0.07);
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 20px;
      --read-max: 720px;
      --shell-max: 1120px;
      --sidebar-w: 240px;
      --font-sans: 'Inter', system-ui, sans-serif;
      --font-serif: 'Noto Serif SC', 'Songti SC', serif;
      --font-display: 'Playfair Display', Georgia, serif;
      --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
    }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    @media (prefers-reduced-motion: reduce) {
      html { scroll-behavior: auto; }
      .curiosity-card.fade-in { animation: none !important; opacity: 1 !important; transform: none !important; }
      .curiosity-card.fade-out { transition: opacity 120ms ease !important; }
    }
    body {
      font-family: var(--font-serif);
      background: var(--bg);
      color: var(--text);
      line-height: 1.65;
      min-height: 100dvh;
      min-height: 100svh;
      font-size: 15px;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    .shell {
      display: flex;
      flex-direction: column;
      min-height: 100dvh;
      max-width: var(--shell-max);
      margin: 0 auto;
      padding: 0 clamp(16px, 4vw, 32px);
    }

    /* —— Top bar: editorial masthead —— */
    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: clamp(20px, 3vw, 28px) 0 clamp(16px, 2vw, 20px);
      border-bottom: 1px solid var(--border);
    }
    .header-brand {
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--text);
    }
    .header-brand small {
      display: block;
      font-family: var(--font-sans);
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-top: 4px;
    }
    .shuffle-btn {
      font-family: var(--font-sans);
      font-size: 13px;
      font-weight: 500;
      color: var(--surface);
      background: var(--accent);
      border: none;
      padding: 10px 18px;
      border-radius: 999px;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      box-shadow: var(--shadow-sm);
      transition: background 180ms var(--ease-out), transform 180ms var(--ease-out), box-shadow 180ms ease;
    }
    .shuffle-btn:hover {
      background: var(--accent-hover);
      box-shadow: 0 4px 16px rgba(196, 92, 62, 0.28);
    }
    .shuffle-btn:active { transform: scale(0.98); }
    .shuffle-btn svg { flex-shrink: 0; }

    .main-grid {
      display: grid;
      grid-template-columns: var(--sidebar-w) minmax(0, 1fr);
      gap: clamp(20px, 3vw, 40px);
      flex: 1;
      align-items: start;
      padding-top: clamp(20px, 3vw, 32px);
      padding-bottom: 32px;
    }

    /* —— Sidebar: calendar strip —— */
    .sidebar {
      position: sticky;
      top: 20px;
      max-height: calc(100dvh - 40px);
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent;
    }
    .sidebar-head {
      font-family: var(--font-sans);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 12px;
      padding-left: 4px;
    }
    .date-list { display: flex; flex-direction: column; gap: 4px; }

    .date-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 8px 10px;
      border-radius: var(--radius-sm);
      cursor: pointer;
      transition: background 150ms ease;
      border: 1px solid transparent;
      background: transparent;
      width: 100%;
      text-align: left;
      font-family: inherit;
    }
    .date-item:hover { background: var(--accent-soft); }
    .date-item.active {
      background: var(--surface);
      border-color: var(--border);
      box-shadow: var(--shadow-sm);
    }
    .date-item.future { opacity: 0.38; cursor: not-allowed; }

    .date-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--border);
      margin-top: 6px;
      flex-shrink: 0;
      transition: background 150ms ease;
    }
    .date-item.active .date-dot {
      background: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-soft);
    }
    .date-item:hover:not(.future) .date-dot { background: var(--accent); }

    .date-info { flex: 1; min-width: 0; }
    .date-label {
      font-family: var(--font-sans);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: var(--text-muted);
      text-transform: uppercase;
    }
    .date-title {
      font-family: var(--font-serif);
      font-size: 12px;
      color: var(--text);
      line-height: 1.45;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin-top: 2px;
    }
    .date-item.active .date-title { color: var(--accent); font-weight: 600; }

    /* —— Article column —— */
    .content-panel { min-width: 0; }

    .curiosity-card {
      background: var(--surface);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-md);
      overflow: hidden;
      border: 1px solid var(--border);
      transition: box-shadow 280ms var(--ease-out);
    }
    .curiosity-card:hover { box-shadow: 0 16px 56px rgba(26, 26, 26, 0.09); }

    .curiosity-card.fade-out {
      opacity: 0;
      transform: translateY(-6px);
      transition: opacity 200ms ease, transform 200ms ease;
    }
    .curiosity-card.fade-in {
      animation: cardIn 420ms var(--ease-out) forwards;
    }
    @keyframes cardIn {
      from { opacity: 0; transform: translateY(14px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .card-media {
      position: relative;
      aspect-ratio: 16 / 9;
      background: linear-gradient(145deg, #EFEBE6 0%, #E4DFD8 100%);
      margin: 0;
    }
    .card-media[hidden] { display: none; }
    .card-img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: opacity 220ms ease;
    }
    .card-img.is-loading {
      opacity: 0;
    }

    .card-inner {
      max-width: var(--read-max);
      margin: 0 auto;
      padding: clamp(24px, 4vw, 40px) clamp(20px, 4vw, 48px) clamp(28px, 4vw, 40px);
    }

    .card-meta {
      font-family: var(--font-sans);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 8px;
    }
    .today-badge {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--surface);
      background: var(--accent);
      padding: 3px 10px;
      border-radius: 999px;
    }

    .card-title {
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 4vw, 1.85rem);
      font-weight: 700;
      line-height: 1.22;
      letter-spacing: -0.02em;
      color: var(--text);
      margin-bottom: 8px;
    }
    .card-subtitle {
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 500;
      color: var(--accent);
      margin-bottom: 24px;
      line-height: 1.5;
    }

    .card-divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 22px;
    }
    .card-divider-line { flex: 1; height: 1px; background: var(--border); }
    .card-divider-mark {
      width: 32px;
      height: 2px;
      background: var(--accent);
      border-radius: 1px;
      opacity: 0.85;
    }

    .card-body-text {
      font-size: 16px;
      line-height: 1.85;
      color: var(--text);
    }
    .card-body-text p { margin-bottom: 1em; }
    .card-body-text p:last-child { margin-bottom: 0; }
    .card-body-text strong, .card-body-text b {
      color: var(--accent);
      font-weight: 600;
    }
    .card-body-text ul, .card-body-text ol { margin: 1em 0; padding-left: 1.35em; }
    .card-body-text li { margin-bottom: 0.35em; }
    .card-body-text a {
      color: var(--accent);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .controls {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
      margin-top: 24px;
      padding: 16px 20px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-sm);
    }
    .nav-btns { display: flex; flex-wrap: wrap; gap: 8px; }
    .nav-btn {
      font-family: var(--font-sans);
      font-size: 13px;
      font-weight: 500;
      color: var(--text-muted);
      background: transparent;
      border: 1px solid var(--border);
      padding: 8px 16px;
      border-radius: 999px;
      cursor: pointer;
      transition: background 160ms ease, color 160ms ease, border-color 160ms ease;
    }
    .nav-btn:hover:not(.disabled) {
      background: var(--text);
      color: var(--bg);
      border-color: var(--text);
    }
    .nav-btn.disabled { opacity: 0.35; cursor: not-allowed; }

    .kbd-hint {
      font-family: var(--font-sans);
      font-size: 10px;
      color: #A8A4A0;
      letter-spacing: 0.02em;
    }
    .kbd {
      display: inline-block;
      padding: 2px 6px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 4px;
      font-size: 9px;
      font-weight: 600;
      color: var(--text-muted);
      margin: 0 2px;
    }
    .credit {
      font-family: var(--font-sans);
      font-size: 10px;
      color: #A8A4A0;
    }

    .footer {
      padding: 20px 0 32px;
      text-align: center;
      font-family: var(--font-sans);
      font-size: 11px;
      color: #A8A4A0;
      letter-spacing: 0.06em;
    }

    :focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    /* —— Mobile & small tablet —— */
    @media (max-width: 768px) {
      body { font-size: 16px; }

      .shell {
        padding: 0;
        max-width: 100%;
      }

      .header {
        padding: 14px max(16px, env(safe-area-inset-right)) 14px max(16px, env(safe-area-inset-left));
        gap: 10px;
        flex-wrap: nowrap;
        align-items: flex-start;
        border-bottom: 1px solid var(--border);
        margin-bottom: 0;
      }
      .header-brand {
        font-size: 1.2rem;
        min-width: 0;
        flex: 1;
      }
      .header-brand small {
        font-size: 9px;
        letter-spacing: 0.12em;
      }
      .shuffle-btn {
        flex-shrink: 0;
        min-height: 44px;
        min-width: 44px;
        padding: 0 14px;
        font-size: 12px;
        gap: 6px;
        -webkit-tap-highlight-color: transparent;
      }
      .shuffle-btn svg { width: 16px; height: 16px; }

      .main-grid {
        display: flex;
        flex-direction: column;
        gap: 0;
        padding-top: 0;
        padding-bottom: max(20px, env(safe-area-inset-bottom));
      }

      /* 先读正文，再横向选日期 */
      .content-panel { order: -1; width: 100%; }
      .sidebar {
        order: 1;
        position: static;
        max-height: none;
        overflow: visible;
        width: 100%;
        padding-top: 12px;
        padding-bottom: 4px;
        border-top: 1px solid var(--border);
        background: linear-gradient(180deg, var(--bg) 0%, rgba(250, 250, 248, 0.98) 100%);
      }
      .sidebar-head {
        padding: 0 max(16px, env(safe-area-inset-left)) 8px max(16px, env(safe-area-inset-right));
        margin-bottom: 0;
      }

      .date-list {
        flex-direction: row;
        overflow-x: auto;
        overflow-y: hidden;
        gap: 10px;
        padding: 4px max(16px, env(safe-area-inset-right)) 14px max(16px, env(safe-area-inset-left));
        margin: 0;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
        overscroll-behavior-x: contain;
        touch-action: pan-x;
      }
      .date-list::-webkit-scrollbar { display: none; }

      .date-item {
        flex-direction: column;
        width: 88px;
        min-height: 76px;
        flex-shrink: 0;
        align-items: center;
        justify-content: center;
        padding: 10px 8px;
        -webkit-tap-highlight-color: transparent;
      }
      .date-dot { display: none; }
      .date-label {
        font-size: 10px;
        text-align: center;
        line-height: 1.3;
      }
      .date-title {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        font-size: 11px;
        margin-top: 4px;
        text-align: center;
      }
      .date-item.active {
        border-color: var(--accent);
        background: var(--accent-soft);
      }

      /* 卡片全宽贴边，更像阅读 App */
      .curiosity-card {
        border-radius: 0;
        border-left: none;
        border-right: none;
        box-shadow: none;
        border-top: none;
        border-bottom: 1px solid var(--border);
      }
      .curiosity-card:hover { box-shadow: none; }

      .card-media {
        aspect-ratio: 16 / 9;
        max-height: min(52vh, 320px);
      }
      .card-img { object-position: center center; }

      .card-inner {
        padding: clamp(18px, 5vw, 24px) max(16px, env(safe-area-inset-left)) clamp(22px, 5vw, 28px) max(16px, env(safe-area-inset-right));
        max-width: none;
      }

      .card-meta {
        font-size: 10px;
        letter-spacing: 0.08em;
        flex-wrap: wrap;
      }
      .card-title {
        font-size: clamp(1.35rem, 5.2vw, 1.65rem);
        line-height: 1.25;
      }
      .card-subtitle {
        font-size: 14px;
        margin-bottom: 20px;
      }
      .card-body-text {
        font-size: 17px;
        line-height: 1.9;
      }

      .controls {
        margin: 16px max(16px, env(safe-area-inset-left)) 0 max(16px, env(safe-area-inset-right));
        padding: 14px 14px;
        flex-direction: column;
        align-items: stretch;
        gap: 12px;
      }
      .nav-btns {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
      }
      #today-btn:not([hidden]) {
        grid-column: 1 / -1;
      }
      .nav-btn {
        min-height: 48px;
        padding: 12px 12px;
        font-size: 14px;
        -webkit-tap-highlight-color: transparent;
      }
      .kbd-hint { display: none; }
      .credit {
        display: block;
        text-align: center;
        font-size: 11px;
      }

      .footer {
        padding: 16px max(16px, env(safe-area-inset-left)) max(24px, calc(12px + env(safe-area-inset-bottom))) max(16px, env(safe-area-inset-right));
        font-size: 11px;
      }
    }

    @media (max-width: 380px) {
      .shuffle-btn .shuffle-label { display: none; }
      .shuffle-btn { padding: 0 12px; }
    }
  </style>
</head>
<body>
  <div class="shell">
    <header class="header">
      <div class="header-brand">
        好奇
        <small>每天一个小好奇</small>
      </div>
      <button type="button" class="shuffle-btn" onclick="shuffleCuriosity()" aria-label="随机换一篇">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
        <span class="shuffle-label">换一篇</span>
      </button>
    </header>

    <div class="main-grid">
      <aside class="sidebar" id="sidebar" aria-label="按日期浏览">
        <div class="sidebar-head">目录</div>
        <div class="date-list" id="date-list"></div>
      </aside>

      <main class="content-panel" id="content-panel">
        <article class="curiosity-card" id="curiosity-card" tabindex="-1">
          <figure class="card-media" id="card-media">
            <img id="card-img" class="card-img" src="" alt="" width="1200" height="675" loading="lazy" decoding="async" />
          </figure>
          <div class="card-inner">
            <div class="card-text">
              <div class="card-meta" id="card-meta"></div>
              <h1 class="card-title" id="card-title"></h1>
              <p class="card-subtitle" id="card-subtitle"></p>
              <div class="card-divider" aria-hidden="true">
                <span class="card-divider-line"></span>
                <span class="card-divider-mark"></span>
                <span class="card-divider-line"></span>
              </div>
              <div class="card-body-text" id="card-body"></div>
            </div>
          </div>
        </article>

        <div class="controls" id="controls">
          <div class="nav-btns">
            <button type="button" class="nav-btn" id="prev-btn" onclick="goToPrev()" aria-label="前一天">← 前一天</button>
            <button type="button" class="nav-btn" id="next-btn" onclick="goToNext()" aria-label="后一天">后一天 →</button>
            <button type="button" class="nav-btn" id="today-btn" onclick="goToToday()" aria-label="回到今天" hidden>今天</button>
          </div>
          <div class="kbd-hint">
            <span class="kbd">←</span><span class="kbd">→</span> 切换日期 &nbsp; <span class="kbd">Space</span> 随机
          </div>
          <div class="credit">每日更新 · 让知识成为一种习惯</div>
        </div>
      </main>
    </div>

    <footer class="footer">每日更新 · 让知识成为一种习惯</footer>
  </div>

  <script>
  const curiositiesDB = [
  {% for item in allCurios %}
  { date: "{{ item.date }}", title: {{ item.title | dump | safe }}, subtitle: {{ item.subtitle | dump | safe }}, image: "{{ item.image }}", body: {{ item.body | dump | safe }} }{% if not loop.last %},{% endif %}
  {% endfor %}
  ];

  let currentIndex = 0;
  let isAnimating = false;
  const today = new Date().toISOString().split('T')[0];

  function formatDate(dateStr) {
    const [y,m,d] = dateStr.split('-');
    const wd = ['周日','周一','周二','周三','周四','周五','周六'][new Date(y,m-1,d).getDay()];
    return `${parseInt(m)}月${parseInt(d)}日 · ${wd}`;
  }

  function isFuture(dateStr) {
    const t = new Date(); t.setHours(0,0,0,0);
    // Use local midnight to avoid UTC timezone issues
    const [y,m,d] = dateStr.split('-');
    return new Date(y, m-1, d) > t;
  }

  function setCardImage(c) {
    const media = document.getElementById('card-media');
    const img = document.getElementById('card-img');
    img.onload = null;
    img.onerror = null;
    if (!c.image || String(c.image).trim() === '') {
      media.hidden = true;
      img.removeAttribute('src');
      img.classList.remove('is-loading');
      return;
    }
    media.hidden = false;
    img.alt = c.title || '好奇配图';
    img.classList.add('is-loading');
    function onLoaded() {
      img.classList.remove('is-loading');
      media.hidden = false;
    }
    img.onload = onLoaded;
    img.onerror = function() {
      img.classList.remove('is-loading');
      media.hidden = true;
    };
    img.src = c.image;
    if (img.complete && img.naturalWidth) onLoaded();
  }

  function focusContentCard() {
    const card = document.getElementById('curiosity-card');
    if (card) card.focus({ preventScroll: false });
  }

  function todayIndex() {
    return curiositiesDB.findIndex(c => c.date === today && !isFuture(c.date));
  }

  function goToToday() {
    const idx = todayIndex();
    if (idx >= 0) goTo(idx, true);
  }

  function buildDateList() {
    const list = document.getElementById('date-list');
    list.innerHTML = '';
    const sorted = [...curiositiesDB].reverse();
    sorted.forEach((c) => {
      const realIdx = curiositiesDB.indexOf(c);
      const item = document.createElement('button');
      const isActive = !isFuture(c.date) && c.date === today;
      const isPast = !isFuture(c.date);
      item.type = 'button';
      item.className = 'date-item' + (isActive ? ' active' : '') + (!isPast ? ' future' : '');
      if (isPast) item.onclick = () => goTo(realIdx, true);
      item.setAttribute('aria-label', `${formatDate(c.date)}：${c.title}`);
      item.setAttribute('aria-current', isActive ? 'true' : 'false');
      item.innerHTML = `
        <span class="date-dot"></span>
        <div class="date-info">
          <div class="date-label">${formatDate(c.date)}</div>
          <div class="date-title">${c.title}</div>
        </div>`;
      list.appendChild(item);
    });
  }

  function goTo(idx, animate) {
    if (isAnimating || idx === currentIndex) return;
    if (isFuture(curiositiesDB[idx]?.date)) return;
    currentIndex = idx;
    if (animate) {
      isAnimating = true;
      const card = document.getElementById('curiosity-card');
      card.classList.remove('fade-in');
      card.classList.add('fade-out');
      setTimeout(() => {
        applyContent(curiositiesDB[currentIndex]);
        card.classList.remove('fade-out');
        card.classList.add('fade-in');
        isAnimating = false;
        history.replaceState({}, '', '?date=' + curiositiesDB[currentIndex].date);
        focusContentCard();
      }, 200);
    } else {
      applyContent(curiositiesDB[currentIndex]);
      history.replaceState({}, '', '?date=' + curiositiesDB[currentIndex].date);
    }
    updateNav();
  }

  function applyContent(c) {
    const futureTag = isFuture(c.date) ? ' <span class="today-badge">未来</span>'
      : (c.date === today ? ' <span class="today-badge">今日</span>' : '');
    document.getElementById('card-meta').innerHTML = formatDate(c.date) + futureTag;
    document.getElementById('card-title').textContent = c.title;
    document.getElementById('card-subtitle').textContent = c.subtitle;
    document.getElementById('card-body').innerHTML = c.body;
    setCardImage(c);
    updateActive();
  }

  function updateActive() {
    const items = document.querySelectorAll('.date-item');
    const sorted = [...curiositiesDB].reverse();
    items.forEach((el, i) => {
      const c = sorted[i];
      const isActive = curiositiesDB[currentIndex].date === c.date && !isFuture(c.date);
      el.classList.toggle('active', isActive);
    });
    const active = document.querySelector('.date-item.active');
    if (active) active.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  }

  function updateNav() {
    const prev = currentIndex - 1;
    const next = currentIndex + 1;
    document.getElementById('prev-btn').classList.toggle('disabled',
      prev < 0 || isFuture(curiositiesDB[prev]?.date));
    document.getElementById('next-btn').classList.toggle('disabled',
      next >= curiositiesDB.length || isFuture(curiositiesDB[next]?.date));
    const tIdx = todayIndex();
    const todayBtn = document.getElementById('today-btn');
    const showToday = tIdx >= 0 && currentIndex !== tIdx;
    todayBtn.hidden = !showToday;
  }

  function goToPrev() {
    const prev = currentIndex - 1;
    if (prev >= 0 && !isFuture(curiositiesDB[prev]?.date)) goTo(prev, true);
  }

  function goToNext() {
    const next = currentIndex + 1;
    if (next < curiositiesDB.length && !isFuture(curiositiesDB[next]?.date)) goTo(next, true);
  }

  function shuffleCuriosity() {
    if (isAnimating) return;
    const valid = curiositiesDB.filter(c => !isFuture(c.date));
    let n;
    do { n = Math.floor(Math.random() * valid.length); }
    while (valid[n].date === curiositiesDB[currentIndex].date && valid.length > 1);
    goTo(curiositiesDB.indexOf(valid[n]), true);
  }

  document.addEventListener('keydown', function(e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
    switch(e.key) {
      case 'ArrowLeft': goToPrev(); break;
      case 'ArrowRight': goToNext(); break;
      case ' ': e.preventDefault(); shuffleCuriosity(); break;
    }
  });

  (function init() {
    buildDateList();
    const urlDate = new URLSearchParams(location.search).get('date');
    const todayIdx = curiositiesDB.findIndex(c => c.date === today && !isFuture(c.date));
    if (urlDate) {
      const idx = curiositiesDB.findIndex(c => c.date === urlDate);
      currentIndex = idx >= 0 ? idx : (todayIdx >= 0 ? todayIdx : curiositiesDB.length - 1);
    } else {
      currentIndex = todayIdx >= 0 ? todayIdx : curiositiesDB.length - 1;
    }
    applyContent(curiositiesDB[currentIndex]);
    updateNav();
    history.replaceState({}, '', '?date=' + curiositiesDB[currentIndex].date);
  })();
  </script>
</body>
</html>
