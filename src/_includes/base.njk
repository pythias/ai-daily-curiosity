<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} - {% endif %}每天一个小好奇</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600&family=Playfair+Display:wght@500;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #FAFAF8;
      --text-primary: #1A1A1A;
      --text-secondary: #6B6B6B;
      --accent: #E85D4C;
      --card-bg: #FFFFFF;
      --border: #EEEEEE;
    }
    body {
      font-family: 'Noto Serif SC', serif;
      background-color: var(--bg);
      color: var(--text-primary);
      line-height: 1.9;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 0 24px;
    }
    .logo {
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 3px;
      color: var(--text-secondary);
      text-transform: uppercase;
      margin-top: 48px;
      margin-bottom: 48px;
    }
    .container { max-width: 720px; width: 100%; }
    .card {
      background: var(--card-bg);
      border-radius: 12px;
      box-shadow: 0 2px 20px rgba(0,0,0,0.04), 0 1px 4px rgba(0,0,0,0.02);
      overflow: hidden;
    }
    .card-img {
      width: 100%;
      aspect-ratio: 16 / 10;
      object-fit: cover;
      display: block;
    }
    .content { padding: 48px; }
    @media (max-width: 600px) { .content { padding: 28px 24px; } }
    .date {
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 1.5px;
      color: var(--text-secondary);
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 24px;
    }
    .divider {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      margin-bottom: 28px;
    }
    .divider-line { width: 48px; height: 1px; background: var(--border); }
    .divider-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--accent); }
    .title {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-weight: 700;
      text-align: center;
      margin-bottom: 32px;
    }
    @media (max-width: 600px) { .title { font-size: 22px; } }
    .subtitle {
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 500;
      color: var(--accent);
      text-align: center;
      margin-bottom: 28px;
    }
    .body-text {
      font-size: 17px;
      text-align: justify;
    }
    .body-text p { margin-bottom: 20px; }
    .body-text p:last-child { margin-bottom: 0; }
    .body-text strong, .body-text b { color: var(--accent); font-weight: 600; }
    .body-text ul, .body-text ol { margin: 16px 0; padding-left: 24px; }
    .body-text li { margin-bottom: 8px; }
    .body-text a { color: var(--accent); text-decoration: underline; }
    .footer {
      margin-top: 48px;
      margin-bottom: 64px;
      text-align: center;
    }
    .nav {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 24px;
      margin-bottom: 20px;
    }
    .nav-btn {
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 1px;
      color: var(--text-secondary);
      background: transparent;
      border: 1px solid var(--border);
      padding: 12px 24px;
      border-radius: 8px;
      cursor: pointer;
      transition: all 200ms ease;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      text-decoration: none;
    }
    .nav-btn:hover:not(.disabled) {
      background: var(--text-primary);
      color: var(--bg);
      border-color: var(--text-primary);
    }
    .nav-btn.disabled { opacity: 0.3; cursor: not-allowed; }
    .shuffle-btn {
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 1px;
      color: var(--text-secondary);
      background: transparent;
      border: 1px solid var(--border);
      padding: 14px 32px;
      border-radius: 8px;
      cursor: pointer;
      transition: all 200ms ease;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 20px;
    }
    .shuffle-btn:hover {
      background: var(--text-primary);
      color: var(--bg);
      border-color: var(--text-primary);
    }
    .today-badge {
      font-family: 'Inter', sans-serif;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 1px;
      color: white;
      background: var(--accent);
      padding: 4px 8px;
      border-radius: 4px;
      margin-left: 8px;
      vertical-align: middle;
    }
    .credit {
      font-family: 'Inter', sans-serif;
      font-size: 11px;
      color: #C0C0C0;
      margin-top: 24px;
      letter-spacing: 0.5px;
    }
    .fade-out { opacity: 0; transform: translateY(-10px); transition: all 300ms ease; }
  </style>
</head>
<body>
  <div class="logo">好奇</div>
  <div class="container">
    {{ content | safe }}
  </div>
</body>
</html>
