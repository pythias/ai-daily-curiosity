<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} - {% endif %}每天一个小好奇</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600&family=Playfair+Display:wght@500;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #FBF7F4;
      --card-bg: #FFFFFF;
      --text-primary: #2D2A26;
      --text-secondary: #8C8680;
      --accent: #E07B54;
      --accent-light: #FDF0EA;
      --border: #F0EBE6;
      --shadow-sm: rgba(45, 42, 38, 0.06);
      --shadow-md: rgba(45, 42, 38, 0.10);
      --text-xs: 11px;
      --text-sm: 12px;
      --text-base: 15px;
      --text-lg: 18px;
      --text-xl: 22px;
      --text-2xl: 28px;
      --space-2: 8px;
      --space-3: 12px;
      --space-4: 16px;
      --space-5: 20px;
      --space-6: 24px;
      --space-8: 32px;
      --sidebar-w: 260px;
      --radius-sm: 10px;
      --radius-md: 16px;
      --radius-lg: 20px;
    }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Noto Serif SC', serif;
      background-color: var(--bg);
      background-image:
        radial-gradient(ellipse at 15% 15%, rgba(224, 123, 84, 0.07) 0%, transparent 45%),
        radial-gradient(ellipse at 85% 85%, rgba(224, 123, 84, 0.04) 0%, transparent 45%);
      color: var(--text-primary);
      line-height: 1.65;
      min-height: 100dvh;
    }

    .shell {
      display: flex;
      flex-direction: column;
      min-height: 100dvh;
      max-width: 1060px;
      margin: 0 auto;
      padding: 0 var(--space-6);
    }

    .header {
      padding: var(--space-6) 0 var(--space-4);
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--border);
      margin-bottom: var(--space-6);
    }
    .header-brand {
      font-family: 'Inter', sans-serif;
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 3px;
      color: var(--text-secondary);
      text-transform: uppercase;
    }

    .main-grid {
      display: grid;
      grid-template-columns: var(--sidebar-w) 1fr;
      gap: var(--space-6);
      flex: 1;
      align-items: start;
    }

    /* ===== Sidebar — Date List ===== */
    .sidebar {
      position: sticky;
      top: var(--space-6);
      max-height: calc(100dvh - 120px);
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent;
      padding-right: var(--space-1);
    }
    .sidebar::-webkit-scrollbar { width: 4px; }
    .sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    .date-list { display: flex; flex-direction: column; gap: var(--space-1); }

    .date-item {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-2) var(--space-3);
      border-radius: var(--radius-sm);
      cursor: pointer;
      transition: background 150ms ease;
      border: 1.5px solid transparent;
      background: transparent;
      width: 100%;
      text-align: left;
      font-family: inherit;
    }
    .date-item:hover { background: var(--accent-light); }
    .date-item.active {
      background: var(--card-bg);
      border-color: var(--accent);
      box-shadow: 0 2px 8px var(--shadow-sm);
    }
    .date-item.future { opacity: 0.4; cursor: not-allowed; }

    .date-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--border);
      flex-shrink: 0;
      transition: background 150ms ease;
    }
    .date-item.active .date-dot { background: var(--accent); box-shadow: 0 0 0 3px var(--accent-light); }
    .date-item:hover .date-dot { background: var(--accent); }

    .date-info { flex: 1; min-width: 0; }
    .date-label {
      font-family: 'Inter', sans-serif;
      font-size: var(--text-xs);
      font-weight: 500;
      color: var(--text-secondary);
      letter-spacing: 0.5px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .date-title {
      font-family: 'Noto Serif SC', serif;
      font-size: var(--text-xs);
      color: var(--text-primary);
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin-top: 2px;
    }
    .date-item.active .date-title { color: var(--accent); font-weight: 600; }

    /* ===== Content Panel ===== */
    .content-panel { min-width: 0; }

    .curiosity-card {
      background: var(--card-bg);
      border-radius: var(--radius-lg);
      box-shadow:
        0 2px 16px var(--shadow-sm),
        0 8px 32px var(--shadow-sm),
        inset 0 1px 0 rgba(255,255,255,0.9);
      overflow: hidden;
      transition: box-shadow 300ms ease;
    }
    .curiosity-card:hover {
      box-shadow:
        0 4px 24px var(--shadow-md),
        0 16px 48px var(--shadow-md),
        inset 0 1px 0 rgba(255,255,255,0.9);
    }
    .curiosity-card.fade-out {
      opacity: 0;
      transform: translateY(-8px) scale(0.99);
      transition: all 200ms ease;
    }
    .curiosity-card.fade-in {
      animation: cardIn 350ms cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    @keyframes cardIn {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .card-text {
      padding: var(--space-8) var(--space-10) var(--space-8);
    }

    .card-meta {
      font-family: 'Inter', sans-serif;
      font-size: var(--text-xs);
      font-weight: 500;
      letter-spacing: 1.5px;
      color: var(--text-secondary);
      text-transform: uppercase;
      margin-bottom: var(--space-3);
      display: flex;
      align-items: center;
      gap: var(--space-2);
    }
    .card-meta::before,
    .card-meta::after {
      content: '';
      display: inline-block;
      width: 20px;
      height: 1px;
      background: var(--border);
    }
    .today-badge {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.5px;
      color: white;
      background: var(--accent);
      padding: 2px 8px;
      border-radius: 20px;
      box-shadow: 0 2px 6px rgba(224, 123, 84, 0.3);
    }

    .card-title {
      font-family: 'Playfair Display', serif;
      font-size: var(--text-2xl);
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.2;
      margin-bottom: var(--space-2);
      letter-spacing: -0.3px;
    }
    .card-subtitle {
      font-family: 'Inter', sans-serif;
      font-size: var(--text-sm);
      font-weight: 500;
      color: var(--accent);
      margin-bottom: var(--space-5);
      opacity: 0.85;
    }

    .card-divider {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      margin-bottom: var(--space-5);
    }
    .card-divider-line { flex: 1; height: 1px; background: var(--border); }
    .card-divider-dot {
      width: 5px; height: 5px; border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-light);
    }

    .card-body-text {
      font-size: var(--text-base);
      line-height: 1.8;
      color: var(--text-primary);
    }
    .card-body-text p { margin-bottom: var(--space-3); }
    .card-body-text p:last-child { margin-bottom: 0; }
    .card-body-text strong, .card-body-text b { color: var(--accent); font-weight: 600; }
    .card-body-text ul, .card-body-text ol { margin: var(--space-3) 0; padding-left: var(--space-6); }
    .card-body-text li { margin-bottom: var(--space-1); }
    .card-body-text a { color: var(--accent); text-decoration: underline; }

    /* ===== Controls ===== */
    .controls {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: var(--space-6);
      padding: var(--space-4) var(--space-6);
      background: var(--card-bg);
      border-radius: var(--radius-md);
      box-shadow: 0 2px 8px var(--shadow-sm);
      gap: var(--space-4);
    }
    .nav-btns { display: flex; gap: var(--space-2); }
    .nav-btn {
      font-family: 'Inter', sans-serif;
      font-size: var(--text-sm);
      font-weight: 500;
      color: var(--text-secondary);
      background: transparent;
      border: 1.5px solid var(--border);
      padding: var(--space-2) var(--space-4);
      border-radius: 50px;
      cursor: pointer;
      transition: all 200ms ease;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .nav-btn:hover:not(.disabled) {
      background: var(--text-primary);
      color: var(--bg);
      border-color: var(--text-primary);
      transform: translateY(-1px);
    }
    .nav-btn.disabled { opacity: 0.3; cursor: not-allowed; }

    .shuffle-btn {
      font-family: 'Inter', sans-serif;
      font-size: var(--text-sm);
      font-weight: 500;
      color: white;
      background: var(--accent);
      border: none;
      padding: var(--space-2) var(--space-5);
      border-radius: 50px;
      cursor: pointer;
      transition: all 200ms ease;
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      box-shadow: 0 3px 10px rgba(224, 123, 84, 0.3);
    }
    .shuffle-btn:hover {
      background: #c96a47;
      box-shadow: 0 5px 16px rgba(224, 123, 84, 0.4);
      transform: translateY(-1px);
    }
    .shuffle-btn:active { transform: translateY(0) scale(0.97); }

    .kbd-hint {
      font-family: 'Inter', sans-serif;
      font-size: 10px;
      color: #C8C4C0;
      letter-spacing: 0.3px;
    }
    .kbd {
      display: inline-block;
      padding: 1px 5px;
      background: var(--border);
      border-radius: 3px;
      font-size: 9px;
      font-weight: 600;
      color: var(--text-secondary);
      margin: 0 1px;
    }
    .credit {
      font-family: 'Inter', sans-serif;
      font-size: 10px;
      color: #C8C4C0;
      letter-spacing: 0.3px;
    }
    .footer {
      padding: var(--space-6) 0 var(--space-8);
      text-align: center;
      font-family: 'Inter', sans-serif;
      font-size: var(--text-xs);
      color: #C8C4C0;
      letter-spacing: 0.5px;
    }

    :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

    /* ===== Mobile ===== */
    @media (max-width: 768px) {
      .shell { padding: 0 var(--space-4); }
      .main-grid { grid-template-columns: 1fr; }
      .sidebar {
        position: static;
        max-height: none;
        overflow: visible;
        padding-right: 0;
        margin-bottom: var(--space-4);
      }
      .date-list {
        flex-direction: row;
        overflow-x: auto;
        gap: var(--space-2);
        padding-bottom: var(--space-2);
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
      }
      .date-list::-webkit-scrollbar { display: none; }
      .date-item {
        flex-direction: column;
        width: 72px;
        flex-shrink: 0;
        padding: var(--space-2);
        gap: var(--space-1);
        align-items: center;
      }
      .date-dot { display: none; }
      .date-info { width: 100%; }
      .date-label { text-align: center; font-size: 10px; }
      .date-title { display: none; }
      .date-item.active::after {
        content: '';
        display: block;
        width: 20px;
        height: 2px;
        background: var(--accent);
        border-radius: 1px;
        margin-top: 2px;
      }
      .card-text { padding: var(--space-5) var(--space-5) var(--space-4); }
      .card-title { font-size: var(--text-xl); }
      .card-subtitle { font-size: 11px; margin-bottom: var(--space-4); }
      .controls {
        flex-wrap: wrap;
        justify-content: center;
        padding: var(--space-3) var(--space-4);
        gap: var(--space-3);
      }
      .kbd-hint, .credit { display: none; }
      .header { padding: var(--space-4) 0 var(--space-3); }
    }
  </style>
</head>
<body>
  <div class="shell">
    <header class="header">
      <div class="header-brand">好奇</div>
      <button class="shuffle-btn" onclick="shuffleCuriosity()" aria-label="随机换一个">
        <span>↻</span> 换一换
      </button>
    </header>

    <div class="main-grid">
      <aside class="sidebar" id="sidebar" aria-label="日期列表">
        <div class="date-list" id="date-list"></div>
      </aside>

      <main class="content-panel" id="content-panel">
        <article class="curiosity-card" id="curiosity-card">
          <div class="card-text">
            <div class="card-meta" id="card-meta"></div>
            <h1 class="card-title" id="card-title"></h1>
            <div class="card-subtitle" id="card-subtitle"></div>
            <div class="card-divider">
              <span class="card-divider-line"></span>
              <span class="card-divider-dot"></span>
              <span class="card-divider-line"></span>
            </div>
            <div class="card-body-text" id="card-body"></div>
          </div>
        </article>

        <div class="controls" id="controls">
          <div class="nav-btns">
            <button class="nav-btn" id="prev-btn" onclick="goToPrev()" aria-label="前一天">← 前一天</button>
            <button class="nav-btn" id="next-btn" onclick="goToNext()" aria-label="后一天">后一天 →</button>
          </div>
          <div class="kbd-hint">
            <span class="kbd">←</span><span class="kbd">→</span> 切换 &nbsp; <span class="kbd">Space</span> 随机
          </div>
          <div class="credit">每日更新 · 让知识成为一种习惯</div>
        </div>
      </main>
    </div>

    <footer class="footer">每日更新 · 让知识成为一种习惯</footer>
  </div>

  <script>
  const curiositiesDB = [
  {% for item in allCurios %}
  { date: "{{ item.date }}", title: {{ item.title | dump | safe }}, subtitle: {{ item.subtitle | dump | safe }}, image: "{{ item.image }}", body: {{ item.body | dump | safe }} }{% if not loop.last %},{% endif %}
  {% endfor %}
  ];

  let currentIndex = 0;
  let isAnimating = false;
  const today = new Date().toISOString().split('T')[0];

  function formatDate(dateStr) {
    const [y,m,d] = dateStr.split('-');
    const wd = ['周日','周一','周二','周三','周四','周五','周六'][new Date(y,m-1,d).getDay()];
    return `${parseInt(m)}月${parseInt(d)}日 ${wd}`;
  }

  function isFuture(dateStr) {
    const t = new Date(); t.setHours(0,0,0,0);
    return new Date(dateStr) > t;
  }

  function buildDateList() {
    const list = document.getElementById('date-list');
    list.innerHTML = '';
    const sorted = [...curiositiesDB].reverse();
    sorted.forEach((c) => {
      const realIdx = curiositiesDB.indexOf(c);
      const item = document.createElement('button');
      const isActive = !isFuture(c.date) && c.date === today;
      const isPast = !isFuture(c.date);
      item.className = 'date-item' + (isActive ? ' active' : '') + (!isPast ? ' future' : '');
      if (isPast) item.onclick = () => goTo(realIdx, true);
      item.setAttribute('aria-label', `${formatDate(c.date)}: ${c.title}`);
      item.setAttribute('aria-current', isActive ? 'true' : 'false');
      item.innerHTML = `
        <span class="date-dot"></span>
        <div class="date-info">
          <div class="date-label">${formatDate(c.date)}</div>
          <div class="date-title">${c.title}</div>
        </div>`;
      list.appendChild(item);
    });
  }

  function goTo(idx, animate) {
    if (isAnimating || idx === currentIndex) return;
    if (isFuture(curiositiesDB[idx]?.date)) return;
    const old = currentIndex;
    currentIndex = idx;
    if (animate) {
      isAnimating = true;
      const card = document.getElementById('curiosity-card');
      card.classList.remove('fade-in');
      card.classList.add('fade-out');
      setTimeout(() => {
        applyContent(curiositiesDB[currentIndex]);
        card.classList.remove('fade-out');
        card.classList.add('fade-in');
        isAnimating = false;
        updateActive();
        history.replaceState({}, '', '?date=' + curiositiesDB[currentIndex].date);
      }, 200);
    } else {
      applyContent(curiositiesDB[currentIndex]);
      history.replaceState({}, '', '?date=' + curiositiesDB[currentIndex].date);
    }
    updateNav();
  }

  function applyContent(c) {
    const futureTag = isFuture(c.date) ? ' <span class="today-badge">未来</span>'
      : (c.date === today ? ' <span class="today-badge">今日</span>' : '');
    document.getElementById('card-meta').innerHTML = formatDate(c.date) + futureTag;
    document.getElementById('card-title').textContent = c.title;
    document.getElementById('card-subtitle').textContent = c.subtitle;
    document.getElementById('card-body').innerHTML = c.body;
    updateActive();
  }

  function updateActive() {
    const items = document.querySelectorAll('.date-item');
    const sorted = [...curiositiesDB].reverse();
    items.forEach((el, i) => {
      const c = sorted[i];
      const isActive = curiositiesDB[currentIndex].date === c.date && !isFuture(c.date);
      el.classList.toggle('active', isActive);
    });
    const active = document.querySelector('.date-item.active');
    if (active) active.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  }

  function updateNav() {
    const prev = currentIndex - 1;
    const next = currentIndex + 1;
    document.getElementById('prev-btn').classList.toggle('disabled',
      prev < 0 || isFuture(curiositiesDB[prev]?.date));
    document.getElementById('next-btn').classList.toggle('disabled',
      next >= curiositiesDB.length || isFuture(curiositiesDB[next]?.date));
  }

  function goToPrev() {
    const prev = currentIndex - 1;
    if (prev >= 0 && !isFuture(curiositiesDB[prev]?.date)) goTo(prev, true);
  }

  function goToNext() {
    const next = currentIndex + 1;
    if (next < curiositiesDB.length && !isFuture(curiositiesDB[next]?.date)) goTo(next, true);
  }

  function shuffleCuriosity() {
    if (isAnimating) return;
    const valid = curiositiesDB.filter(c => !isFuture(c.date));
    let n;
    do { n = Math.floor(Math.random() * valid.length); }
    while (valid[n].date === curiositiesDB[currentIndex].date && valid.length > 1);
    goTo(curiositiesDB.indexOf(valid[n]), true);
  }

  document.addEventListener('keydown', function(e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
    switch(e.key) {
      case 'ArrowLeft': goToPrev(); break;
      case 'ArrowRight': goToNext(); break;
      case ' ': e.preventDefault(); shuffleCuriosity(); break;
    }
  });

  (function init() {
    buildDateList();
    const urlDate = new URLSearchParams(location.search).get('date');
    const todayIdx = curiositiesDB.findIndex(c => c.date === today && !isFuture(c.date));
    if (urlDate) {
      const idx = curiositiesDB.findIndex(c => c.date === urlDate);
      currentIndex = idx >= 0 ? idx : (todayIdx >= 0 ? todayIdx : curiositiesDB.length - 1);
    } else {
      currentIndex = todayIdx >= 0 ? todayIdx : curiositiesDB.length - 1;
    }
    applyContent(curiositiesDB[currentIndex]);
    updateNav();
    history.replaceState({}, '', '?date=' + curiositiesDB[currentIndex].date);
  })();
  </script>
</body>
</html>
